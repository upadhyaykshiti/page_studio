# Contentful
CONTENTFUL_SPACE_ID=your_space_id
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_DELIVERY_TOKEN=your_delivery_token
CONTENTFUL_PREVIEW_TOKEN=your_preview_token
# Only needed to run `npm run contentful:setup` (creates content types + seed data).
# Not read by the running app — safe to omit after setup.
CONTENTFUL_MANAGEMENT_TOKEN=your_management_token
# When set to "mock", the adapter serves local fixture data instead of calling Contentful.
CONTENT_SOURCE=mock



